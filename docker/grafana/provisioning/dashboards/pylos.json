{
  "title": "Pylos AI Gateway",
  "uid": "pylos-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(pylos_inference_requests_total)",
          "legendFormat": "Total"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(pylos_inference_success_total) / sum(pylos_inference_requests_total) * 100",
          "legendFormat": "%"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "percent"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "In Flight",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "pylos_inference_in_flight",
          "legendFormat": "Requests"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Errors",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(pylos_inference_errors_total)",
          "legendFormat": "Errors"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(pylos_inference_requests_total[1m])) by (provider)",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "P50/P95/P99 Latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(pylos_inference_duration_seconds_bucket[1m])) by (le, provider))",
          "legendFormat": "p50 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pylos_inference_duration_seconds_bucket[1m])) by (le, provider))",
          "legendFormat": "p95 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(pylos_inference_duration_seconds_bucket[1m])) by (le, provider))",
          "legendFormat": "p99 {{provider}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tokens Used",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(pylos_prompt_tokens_total[1m])) by (provider)",
          "legendFormat": "prompt {{provider}}"
        },
        {
          "expr": "sum(rate(pylos_completion_tokens_total[1m])) by (provider)",
          "legendFormat": "completion {{provider}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Rate by Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(pylos_inference_errors_total[1m])) by (error_type)",
          "legendFormat": "{{error_type}}"
        }
      ]
    }
  ]
}
