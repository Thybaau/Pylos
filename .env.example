# ─────────────────────────────────────────────────────────────────────────────
# Pylos — Configuration locale
# Copier ce fichier en .env et remplir les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ── Providers HTTP ────────────────────────────────────────────────────────────

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# URL de base OpenAI-compatible (optionnel)
# Exemples :
#   Groq    → https://api.groq.com/openai/v1
#   Ollama  → http://host.docker.internal:11434/v1
#   OpenRouter → https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# Option 1 — Credentials explicites
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Option 2 — IAM Role (pour ECS/EKS/EC2 avec instance profile, laisser vide)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockRole

# Région Bedrock
AWS_REGION=us-east-1

# ── Fichier de config Pylos ───────────────────────────────────────────────────
# Chemin vers pylos.json (optionnel — auto-détection via env vars si absent)
# PYLOS_CONFIG=/app/pylos.json

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000
RUST_LOG=info

# ── Mem0 Memory Sidecar ───────────────────────────────────────────────────────
# URL du sidecar mémoire (utilisé par le plugin Rust Mem0Plugin)
# MEM0_SIDECAR_URL=http://mem0-sidecar:7577

# Backend de stockage pour Mem0 (postgres, qdrant, chroma, elasticsearch)
# MEM0_BACKEND=postgres

# URL de connexion au backend
# MEM0_BACKEND_URL=postgres://postgres:postgres@postgres:5432/mem0

# Nom de la collection/table Mem0
# MEM0_COLLECTION_NAME=pylos-memories

# Modèle d'embedding
# MEM0_EMBEDDING_MODEL=nomic-embed-text-v2-moe-GGUF

# Provider d'embedding (openai, ollama)
# MEM0_EMBEDDING_PROVIDER=ollama

# URL de base du provider d'embedding
# MEM0_EMBEDDING_BASE_URL=http://192.168.0.58:11434/v1

# Budget maximum de tokens pour le contexte mémoire injecté
# MEM0_MAX_CONTEXT_TOKENS=2048

# TTL par défaut des entrées mémoire (secondes, 0 = pas de TTL)
# MEM0_TTL_SECONDS=86400

# Niveau de log du sidecar
# MEM0_LOG_LEVEL=INFO
